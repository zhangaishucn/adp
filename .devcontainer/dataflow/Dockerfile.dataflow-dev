FROM ubuntu:22.04

# --- 1. 基础参数与系统工具 (保持高效缓存) ---
ARG USERNAME=devuser
ARG USER_UID=1000
ARG USER_GID=1000
ARG GO_VERSION=1.24.0

RUN apt-get update && export DEBIAN_FRONTEND=noninteractive \
    && apt-get install -y --no-install-recommends \
    build-essential ca-certificates curl git vim wget sudo gnupg lsof \
    && rm -rf /var/lib/apt/lists/*

# --- 2. 安装 Go 二进制文件 ---
RUN wget -qO- https://golang.org/dl/go${GO_VERSION}.linux-amd64.tar.gz | tar -C /usr/local -xzf -

# --- 3. 创建非 root 用户 ---
RUN groupadd --gid ${USER_GID} ${USERNAME} \
    && useradd --uid ${USER_UID} --gid ${USER_GID} -m ${USERNAME} -s /bin/bash \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME}

# --- 4. 配置环境变量 ---
ENV GOPATH="/home/${USERNAME}/go"
ENV PATH="/usr/local/go/bin:${GOPATH}/bin:${PATH}"

# 预创建目录并赋权 (Root 身份执行)
RUN mkdir -p ${GOPATH}/bin ${GOPATH}/src ${GOPATH}/pkg \
    && chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}

# --- 5. 切换用户并安装 Go 工具链 ---
USER ${USERNAME}
WORKDIR /home/${USERNAME}

# 使用 go install 安装常用开发工具
# 这些工具会被放置在 ${GOPATH}/bin 目录下
# RUN go install github.com/go-delve/delve/cmd/dlv@latest && \
#     go install github.com/golang/mock/mockgen@latest && \
#     go install golang.org/x/tools/gopls@latest && \
#     go install github.com/ramya-rao-a/go-outline@latest && \
#     go install honnef.co/go/tools/cmd/staticcheck@latest

# 提示：如果工具较多，可以考虑用 ARG 触发缓存刷新
CMD ["sleep", "infinity"]